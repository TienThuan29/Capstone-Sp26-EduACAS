# ============================================================
# EduACAS - Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.production .env
#
# ============================================================

# ─── Domain / URL (REPLACE with your actual domain) ─────────────
# The public-facing domain where your app will be hosted
DOMAIN=your-domain.com
FRONTEND_URL=http://your-domain.com
BACKEND_BASE_URL=http://your-domain.com

# ─── ASP.NET Core ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# ─── AWS (REQUIRED - for DynamoDB & S3) ───────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here

# ─── Redis (internal) ──────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password_in_production

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=change_this_rabbitmq_password_in_production
RABBITMQ_VIRTUAL_HOST=/

# ─── JWT / Auth ───────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_strong_random_secret_min_64_chars
JWT_ISSUER=AuthService
JWT_AUDIENCE=AcasService
JWT_ACCESS_TOKEN_EXPIRATION=1d
JWT_REFRESH_TOKEN_EXPIRATION=7d
BCRYPT_SALT_ROUNDS=12
HASHING_SECRET_KEY=change_this_to_another_strong_random_secret

# ─── Google OAuth (REQUIRED) ──────────────────────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# IMPORTANT: Update Authorized JavaScript origins and Redirect URIs
# in Google Cloud Console to include your domain

# ─── DynamoDB Tables ──────────────────────────────────────────
DYNAMODB_USER_TABLE=acas-users
DYNAMODB_CLASSROOM_TABLE=acas-classrooms
DYNAMODB_CLASSROOM_ENROLLMENT_TABLE=acas-classroom-enrollments
DYNAMODB_COMMENT_TABLE=acas-comments
DYNAMODB_DISCUSSION_ISSUE_TABLE=acas-discussion-issues
DYNAMODB_EXAMINATION_TABLE=acas-examinations
DYNAMODB_MATERIAL_TABLE=acas-materials
DYNAMODB_PROBLEM_TABLE=acas-problems
DYNAMODB_PROGRAMMING_LANGUAGE_TABLE=acas-programming-languages
DYNAMODB_REGRADING_REQUEST_TABLE=acas-regrading-requests
DYNAMODB_SLOT_TABLE=acas-slots
DYNAMODB_SUBJECT_TABLE=acas-subjects
DYNAMODB_SUBMISSION_TABLE=acas-submissions
DYNAMODB_NOTIFICATION_TABLE=acas-notifications
DYNAMODB_KEYSTROKE_LOGS_TABLE=acas-keystroke-logs
DYNAMODB_USER_DEVICE_TABLE=acas-user-devices
DYNAMODB_QUIZ_TABLE=acas-quizzes
DYNAMODB_QUESTION_TABLE=acas-questions
DYNAMODB_ANSWER_OPTION_TABLE=acas-answer-options
DYNAMODB_CLASSROOM_QUIZ_TABLE=acas-classroom-quizzes
DYNAMODB_QUIZ_ATTEMPT_TABLE=acas-quiz-attempts
DYNAMODB_STUDENT_ANSWER_TABLE=acas-student-answers
DYNAMODB_ERROR_GROUP_TABLE=acas-error-groups
DYNAMODB_EXAM_LOG_TABLE=acas-exam-logs
DYNAMODB_STUDENT_EXAM_SESSION_TABLE=acas-student-exam-sessions
DYNAMODB_EXAMINATION_TEMPLATE_TABLE=acas-examination-templates
DYNAMODB_ACADEMIC_WARNING_TABLE=acas-academic-warnings

# ─── S3 Buckets ───────────────────────────────────────────────
S3_PUBLIC_BUCKET=acas-public-storage
S3_PRIVATE_BUCKET=acas-private-storage

# ─── Code Runner ──────────────────────────────────────────────
CODERUNNER_IMAGE=tienthuan29/code-runner-nestjs:latest

# ─── Gemini AI (optional) ─────────────────────────────────────
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Azure Form Recognizer ────────────────────────────────────
# NOTE: Azure Form Recognizer config is NOT set here because the
# appsettings.json (embedded in the Docker image) already contains
# the real values. If you need to override, set the real values below.
AZURE_FORM_RECOGNIZER_ENDPOINT=https://ocr-doan-khoanfpt.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_API_KEY=4EDesWLrweYsZVWyfQ75zIlapo9VcxAzuaCwfQniyjmQFngyOCJgJQQJ99CBACNns7RXJ3w3AAALACOGrmFr

# ─── SMTP / Email (optional) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM_ADDRESS=noreply@your-domain.com
SMTP_FROM_NAME=EduACAS
SMTP_ENABLE_SSL=true
SMTP_USE_DEFAULT_CREDENTIALS=false
