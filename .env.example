# ============================================================
# EduACAS - All Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required: AWS and Google OAuth credentials (core functionality)
# Optional: Gemini, Azure OCR, SMTP, Firebase (enhanced features)
# ============================================================

# ─── ASP.NET Core (do not change) ─────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ─── AWS (REQUIRED - for DynamoDB & S3) ───────────────────────
# Obtain from AWS IAM console → Security credentials
# Region is fixed to ap-southeast-1 (Singapore) for DynamoDB
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here

# ─── Google OAuth (REQUIRED - for user login) ─────────────────
# Obtain from Google Cloud Console → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID for Web application
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Frontend / CORS ───────────────────────────────────────────
# URL of the Next.js web app (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# ─── Redis ────────────────────────────────────────────────────
# Already configured in compose (redis:6379 inside Docker network)
# External port: 6379
REDIS_CONNECTION_STRING=redis:6379

# ─── RabbitMQ ─────────────────────────────────────────────────
# Already configured in compose (rabbitmq inside Docker network)
# External ports: 5672 (AMQP), 15672 (Management UI)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VIRTUAL_HOST=/

# ─── JWT / Auth ───────────────────────────────────────────────
# Shared secret between AuthService and AcasService (must match)
JWT_SECRET=a515eacc2bb80a220252fa157bd8dfcaa53bc18c4ecb7666241db1139dafaedd
JWT_ISSUER=AuthService
JWT_AUDIENCE=AcasService
JWT_ACCESS_TOKEN_EXPIRATION=1d
JWT_REFRESH_TOKEN_EXPIRATION=7d
BCRYPT_SALT_ROUNDS=12

# Internal hashing key used for cross-service data integrity
HASHING_SECRET_KEY=THUAN_DEP_ZAI_VCL

# ─── DynamoDB Tables ───────────────────────────────────────────
# AcasService tables
DYNAMODB_CLASSROOM_TABLE=acas-classrooms
DYNAMODB_CLASSROOM_ENROLLMENT_TABLE=acas-classroom-enrollments
DYNAMODB_COMMENT_TABLE=acas-comments
DYNAMODB_DISCUSSION_ISSUE_TABLE=acas-discussion-issues
DYNAMODB_EXAMINATION_TABLE=acas-examinations
DYNAMODB_MATERIAL_TABLE=acas-materials
DYNAMODB_PROBLEM_TABLE=acas-problems
DYNAMODB_PROGRAMMING_LANGUAGE_TABLE=acas-programming-languages
DYNAMODB_REGRADING_REQUEST_TABLE=acas-regrading-requests
DYNAMODB_SLOT_TABLE=acas-slots
DYNAMODB_SUBJECT_TABLE=acas-subjects
DYNAMODB_SUBMISSION_TABLE=acas-submissions
DYNAMODB_NOTIFICATION_TABLE=acas-notifications
DYNAMODB_KEYSTROKE_LOGS_TABLE=acas-keystroke-logs
DYNAMODB_USER_DEVICE_TABLE=acas-user-devices
DYNAMODB_QUIZ_TABLE=acas-quizzes
DYNAMODB_QUESTION_TABLE=acas-questions
DYNAMODB_ANSWER_OPTION_TABLE=acas-answer-options
DYNAMODB_CLASSROOM_QUIZ_TABLE=acas-classroom-quizzes
DYNAMODB_QUIZ_ATTEMPT_TABLE=acas-quiz-attempts
DYNAMODB_STUDENT_ANSWER_TABLE=acas-student-answers
DYNAMODB_ERROR_GROUP_TABLE=acas-error-groups
DYNAMODB_EXAM_LOG_TABLE=acas-exam-logs
DYNAMODB_STUDENT_EXAM_SESSION_TABLE=acas-student-exam-sessions
DYNAMODB_EXAMINATION_TEMPLATE_TABLE=acas-examination-templates
DYNAMODB_ACADEMIC_WARNING_TABLE=acas-academic-warnings
# Dev / cross-service
DYNAMODB_USER_TABLE=acas-users

# ─── S3 Buckets ───────────────────────────────────────────────
S3_PUBLIC_BUCKET=acas-public-storage
S3_PRIVATE_BUCKET=acas-private-storage

# ─── Code Runner ─────────────────────────────────────────────
# Internal URL for AcasService to call the code execution service
CODERUNNER_BASE_URL=http://code-runner:5000

# ─── Gemini AI (OPTIONAL - for auto-grading) ──────────────────
# Obtain from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_MODEL_NAME=gemini-3-flash-preview
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Azure Form Recognizer (OPTIONAL - for OCR/scanning) ──────
# Obtain from Azure Portal → Azure AI services → Document Intelligence
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_API_KEY=your_azure_api_key_here

# ─── SMTP / Email (OPTIONAL - for notifications) ─────────────
# Use Gmail App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=automatedassessment.system@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM_ADDRESS=noreply@eduacas.com
SMTP_FROM_NAME=EduACAS
SMTP_ENABLE_SSL=true
SMTP_USE_DEFAULT_CREDENTIALS=false

# ─── Firebase (OPTIONAL - for push notifications) ────────────
# Path to Firebase service account JSON file (mounted in container)
# The JSON content is in appsettings.json; copy it to this path
FIREBASE_SERVICE_ACCOUNT_FILE=appsettings.json
# Or set the JSON directly as an env var (FIREBASE_SERVICE_ACCOUNT_JSON)
